server:
  port: 8080

db:
  host: 127.0.0.1
  port: 3306
  user: root
  password: ""
  dbname: ctf

jwt:
  secret: "change-me-in-production"
  admin_role: "admin"

rate_limit:
  submission:
    requests: 3
    window: 10s

log:
  # path: "logs/server.log"    # 日志文件路径，注释掉则仅输出到 stdout
  level: "info"                # debug / info / warn / error

auth:
  url: "http://localhost:8081" # 认证服务地址

cache:
  default_ttl: 5m              # 默认缓存过期时间
  cleanup_interval: 10m        # 后台清理间隔，0 表示不启动后台清理
